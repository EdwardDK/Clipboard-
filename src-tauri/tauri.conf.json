{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clipboard+",
  "version": "0.1.1",
  "identifier": "com.clipboardplus.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "label": "main",
      "title": "Clipboard+",
      "width": 980,
      "height": 650,
      "minWidth": 720,
      "minHeight": 500,
      "visible": false,
      "resizable": true,
      "center": true
    }],
    "security": { "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data:;" }
  },
  "bundle": { "active": true, "targets": "all", "icon": ["icons/icon.ico"] }
}
